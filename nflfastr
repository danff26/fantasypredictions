extract_position_counts_off <-
  function(personnel) {
    counts <-
      str_extract_all(personnel, "\\d+")[[1]]
    counts <- as.integer(counts)
    if(length(counts) == 3) {
      counts <- c(0,counts)
    }
    return(counts)
  }
