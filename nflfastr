pick_col <- function(df, candidates, default = 0) {
  hit <- candidates[candidates %in% names(df)]
  if (length(hit)) {
    vec <- df[[hit[1]]]
    # coerce logicals to numeric if needed
    if (is.logical(vec)) vec <- as.integer(vec)
    vec
  } else {
    rep(default, nrow(df))
  }
}
unique_game_id <- function(x) {
  columns_to_check <-
    c("game_id")
  duplicates <-
    x[duplicated(x[columns_to_check]) |
        duplicated(x[columns_to_check], fromLast = TRUE),]
  unique_data <- x |> distinct(across(all_of(columns_to_check)),.keep_all = TRUE)
  x <- unique_data}
