  dplyr::mutate(WK = suppressWarnings(as.integer(WK)))

avg_has_weekly_rows <- "WK" %in% names(qb_avg_eval_base) &&
  dplyr::n_distinct(paste(qb_avg_eval_base$Player, qb_avg_eval_base$TM, qb_avg_eval_base$WK, sep = "|")) >
  dplyr::n_distinct(paste(qb_avg_eval_base$Player, qb_avg_eval_base$TM, sep = "|"))

join_keys <- if (avg_has_weekly_rows) c("Player", "TM", "WK") else c("Player", "TM")

qb_avg_eval_join <- if (avg_has_weekly_rows) {
  qb_avg_eval_base %>%
    dplyr::arrange(Player, TM, WK) %>%
    dplyr::distinct(Player, TM, WK, .keep_all = TRUE)
} else {
  qb_avg_eval_base %>%
    dplyr::arrange(Player, TM) %>%
    dplyr::distinct(Player, TM, .keep_all = TRUE)
}

