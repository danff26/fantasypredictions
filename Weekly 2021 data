  rename(defteam = team_abbr)|>
  filter(season == 2021 & week == 2)
metric_stats_def_wk2 <- pbp_2021_wk2 |>
  left_join(next_gen_2021_wk2_def, by = c("defteam", "season","week"))|>
  mutate(defteam = ifelse(defteam == "LA","LAR",defteam))|>
  group_by(defteam)|>
  mutate(pass_plays = ifelse(play_type == "pass",1,0),
         run_plays = ifelse(play_type == "run",1,0))|>
  filter(!is.na(pass_plays) & !is.na(run_plays))|>
  group_by(defteam)|>
  mutate(tot_pass_plays = sum(pass_plays),
         tot_run_plays = sum(run_plays),
         tot_plays = tot_pass_plays + tot_run_plays,
         pass_pct = round((tot_pass_plays / tot_plays)*100,1),
         run_pct = round((tot_run_plays / tot_plays)*100,1),
         qb_drp = sum(qb_dropback),
         sack_allw = sum(sack),
         sack_allw_pct = round((sack_allw / qb_drp)*100,1),
         field_goal_made = ifelse(field_goal_result == "made",3,0),
         extra_point_made = ifelse(extra_point_result == "good",1,0),
         field_goal_made = if_else(is.na(field_goal_made), 0, field_goal_made),
         extra_point_made = if_else(is.na(extra_point_made), 0, extra_point_made),
         points_scored = (touchdown * 6) + field_goal_made + extra_point_made,
         game_score = sum(points_scored),
         pass_yards = ifelse(pass_plays == 1, yards_gained,0),
         rush_yards = ifelse(run_plays == 1, yards_gained,0),
         tot_yards = sum(yards_gained),
         tot_pass_yds = sum(pass_yards),
         tot_run_yds = sum(rush_yards),
         pass_yds_pp = tot_pass_yds / tot_pass_plays,
         air_yards = ifelse(is.na(air_yards),0,air_yards),
         tot_air_yards = sum(air_yards),
         air_yards_pa = tot_air_yards / tot_pass_plays,
         yards_after_catch = ifelse(!is.na(yards_after_catch),yards_after_catch,0),
         yacatch = sum(yards_after_catch),
         yacatch_pa = yacatch / tot_pass_plays,
         run_yds_pp = tot_run_yds / tot_run_plays,
         yds_pp = tot_yards / tot_plays,
         yds_pa = tot_pass_yds / tot_pass_plays,
         yds_run = tot_run_yds / tot_run_plays,
         run_inside = ifelse(run_location == "middle" | run_gap == "guard",1,0),
         run_inside = ifelse(is.na(run_inside),0,run_inside),
         run_inside_car = sum(run_inside),
         run_inside_yards = sum(ifelse(run_inside == 1, yards_gained,0)),
         run_inside_ypc = run_inside_yards / run_inside_car,
         run_outside = ifelse(run_gap == "tackle" | run_gap == "end",1,0),
         run_outside = ifelse(is.na(run_outside),0,run_outside),
         run_outside_car = sum(run_outside),
         run_outside_yards = sum(ifelse(run_outside == 1, yards_gained,0)),
         run_outside_ypc = run_outside_yards / run_outside_car,
         run_left = ifelse(run_location == "left",1,0),
         run_left = ifelse(is.na(run_left),0,run_left),
         run_left_car = sum(run_left),
         run_left_yards = sum(ifelse(run_left == 1, yards_gained,0)),
         run_left_ypc = run_left_yards / run_left_car,
         run_right = ifelse(run_location == "right",1,0),
         run_right = ifelse(is.na(run_right),0,run_right),
         run_right_car = sum(run_right),
         run_right_yards = sum(ifelse(run_right == 1, yards_gained,0)),
         run_right_ypc = run_right_yards / run_right_car,
         qb_scrambles = sum(qb_scramble),
         qb_scramble_yds = sum(ifelse(qb_scramble == 1,yards_gained,0)),
         tot_tds = sum(touchdown),
         pass_tds <- sum(ifelse(play_type == "pass" & touchdown == 1, 1,0)),
         run_tds = sum(ifelse(play_type == "run" & touchdown == 1,1,0)),
         tot_epa = sum(epa),
         pass_epa = sum(ifelse(play_type == "pass", epa,0)),
         run_epa = sum(ifelse(play_type == "run", epa, 0)),
         tot_epa_pp = tot_epa / tot_plays,
         pass_epa_pp = pass_epa / tot_pass_plays,
         run_epa_pp = run_epa / tot_run_plays,
  )
