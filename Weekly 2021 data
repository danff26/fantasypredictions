    Team_Oline_Press_Role = dplyr::case_when(
      Oline_Press_Grade_0to100 >= 80 ~ "Clean Pocket",
      Oline_Press_Grade_0to100 >= 60 ~ "Protected",
      Oline_Press_Grade_0to100 >= 40 ~ "Balanced Pressure",
      Oline_Press_Grade_0to100 >= 20 ~ "On the Run",
