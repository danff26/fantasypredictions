    HC_INLINE_TGT_Role = mk_role(INLINE_TGT_RATE, c("TE Featured","TE Focus","TE Balance","TE Unemphasized","TE Non Focal")),
    HC_BACK_TGT_Role   = mk_role_skew(BACK_TGT_RATE, c("Checkdown Featured","Checkdown Focus","Checkdown Balance","Checkdown Unemphasized","Checkdown Non Focal")),
