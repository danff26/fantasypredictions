r <- get("team_rush_metrics_21_wk6", inherits = TRUE)
c <- get("team_rec_metrics_21_wk6",  inherits = TRUE)
k <- get("kicking_21_wk6",           inherits = TRUE)

# ---- Pipeline ----
team_offense_21_wk6 <- p %>%
  left_join(r, by = c("Name","TM","SEA","WK","G"), suffix = c("_pass","_rush")) %>%
  left_join(c, by = c("Name","TM","SEA","WK","G"), suffix = c("", "_rec")) %>%
  mutate(
    Head_Coach = head_coach_pass,
    TM_DEF = dplyr::case_when(
      TM_DEF == "ARZ" ~ "ARI",
      TM_DEF == "HST" ~ "HOU",
      TM_DEF == "BLT" ~ "BAL",
      TM_DEF == "LA"  ~ "LAR",
      TM_DEF == "CLV" ~ "CLE",
      TRUE ~ TM_DEF
    ),
    Head_Coach = factor(Head_Coach)
  ) %>%
  left_join(k, by = c("TM","SEA","WK","G","TM_DEF","Head_Coach")) %>%
  mutate(
    Pts_scr = coalesce(TD_pass, 0) * 6 +
      coalesce(TD_rush, 0) * 6 +
      coalesce(epsMade, 0) * 1 +
      coalesce(complete19, 0) * 3 +
      coalesce(complete29, 0) * 3 +
      coalesce(complete39, 0) * 3 +
      coalesce(complete49, 0) * 3 +
      coalesce(complete50, 0) * 3
  ) %>%
  # Pace & roles
  mutate(
    tot_pass_plays = suppressWarnings(as.numeric(tot_pass_plays)),
    tot_run_plays  = suppressWarnings(as.numeric(tot_run_plays)),
    total_plys = coalesce(tot_pass_plays, 0) + coalesce(tot_run_plays, 0),
    Pass_pct  = round((coalesce(tot_pass_plays,0) / pmax(total_plys, 1)) * 100, 1),
    Run_pct   = round((coalesce(tot_run_plays,0)  / pmax(total_plys, 1)) * 100, 1),
    HC_pace_Role = mk_role(total_plys, c("Up_Tempo","Fast_Paced","Average_Paced","Slow_Paced","Snail_Paced")),
    HC_Pass_Run_Role = mk_role(Pass_pct, c("Air it Out","Pass Balanced","Balanced","Run Balanced","Grind it Out"))
  ) %>%
  # Pass eff/style
  mutate(
    YPA  = suppressWarnings(as.numeric(YPA)),
    aDOT = suppressWarnings(as.numeric(aDOT)),
    HC_Pass_Eff_Role   = mk_role(YPA,  c("Elite Efficient","Efficient","League Average","Inefficient","Subpar")),
    HC_Pass_Style_Role = mk_role(aDOT, c("Vertical","Aggressive","League Average","Short Attack","Dink and Dunk"), use_median_mean_diff = FALSE)
  ) %>%
  # Gap/Zone, YAC design, rush eff
  mutate(
    CAR   = suppressWarnings(as.numeric(CAR)),
    CAR_M = suppressWarnings(as.numeric(CAR_M)),
    CAR_Z = suppressWarnings(as.numeric(CAR_Z)),
    Gap_pct  = round((coalesce(CAR_M,0) / pmax(coalesce(CAR,0), 1)) * 100, 1),
    Zone_pct = round((coalesce(CAR_Z,0) / pmax(coalesce(CAR,0), 1)) * 100, 1),
    HC_GapvsZone_Role = mk_role(Gap_pct, c("Gap Heavy","Gap Balanced","Balanced","Zone Balanced","Zone Heavy")),
    YAC_PCT = pct_num(YAC_PCT),
    HC_YAC_Design_Role = mk_role(YAC_PCT, c("YAC King Design","YAC Earner Design","YAC Average Design","YAC Moderate Design","YAC Minimal Design")),
    YPC = suppressWarnings(as.numeric(YPC)),
    HC_Rush_Eff_Role = mk_role(YPC, c("Elite Efficient Rush","Efficient Rush","Average Rush","Inefficient Rush","Subpar Rush"))
  ) %>%
  # Target-rate roles + WR profile
  mutate(
    WIDE_TGT_RATE   = pct_num(WIDE_TGT_RATE),
    SLOT_TGT_RATE   = pct_num(SLOT_TGT_RATE),
    INLINE_TGT_RATE = coalesce(pct_num(INLINE_TGT_RATE), 0),
    BACK_TGT_RATE   = pct_num(BACK_TGT_RATE),
    HC_WIDE_TGT_Role = mk_role_skew(WIDE_TGT_RATE, c("Perimeter Featured","Perimeter Focus","Perimeter Balance","Perimeter Unemphasized","Perimeter Non Focal")),
    HC_SLOT_TGT_Role = mk_role(SLOT_TGT_RATE, c("Slot Featured","Slot Focus","Slot Balance","Slot Unemphasized","Slot Non Focal")),
    HC_INLINE_TGT_Role = mk_role(INLINE_TGT_RATE, c("TE Featured","TE Focus","TE Balance","TE Unemphasized","TE Non Focal")),
    HC_BACK_TGT_Role   = mk_role_skew(BACK_TGT_RATE, c("Checkdown Featured","Checkdown Focus","Checkdown Balance","Checkdown Unemphasized","Checkdown Non Focal")),
    HC_WR_TGT_Role = dplyr::case_when(
      (HC_WIDE_TGT_Role %in% c("Perimeter Featured","Perimeter Focus")) & (HC_SLOT_TGT_Role %in% c("Slot Unemphasized","Slot Non Focal")) ~ "Perimeter Featured",
      (HC_WIDE_TGT_Role %in% c("Perimeter Unemphasized","Perimeter Non Focal")) & (HC_SLOT_TGT_Role %in% c("Slot Featured","Slot Focus")) ~ "Slot Featured",
      (HC_WIDE_TGT_Role == "Perimeter Balance") & (HC_SLOT_TGT_Role == "Slot Balance") ~ "Balance",
      (HC_WIDE_TGT_Role %in% c("Perimeter Featured","Perimeter Focus")) & (HC_SLOT_TGT_Role == "Slot Balance") ~ "Perimeter Lean",
      (HC_WIDE_TGT_Role == "Perimeter Balance") & (HC_SLOT_TGT_Role %in% c("Slot Featured","Slot Focus")) ~ "Slot Lean",
      (HC_WIDE_TGT_Role %in% c("Perimeter Featured","Perimeter Focus")) & (HC_SLOT_TGT_Role %in% c("Slot Featured","Slot Focus")) ~ "WR Featured",
      (HC_WIDE_TGT_Role %in% c("Perimeter Unemphasized","Perimeter Non Focal")) & (HC_SLOT_TGT_Role == "Slot Balance") ~ "WR Slot Limited",
      (HC_WIDE_TGT_Role == "Perimeter Balance") & (HC_SLOT_TGT_Role %in% c("Slot Unemphasized","Slot Non Focal")) ~ "WR Wide Limited",
      (HC_WIDE_TGT_Role %in% c("Perimeter Unemphasized","Perimeter Non Focal")) & (HC_SLOT_TGT_Role %in% c("Slot Unemphasized","Slot Non Focal")) ~ "WR Non Focal",
      TRUE ~ NA_character_
    ) %>% factor(levels = c("Perimeter Featured","Slot Featured","Balance","Perimeter Lean","Slot Lean","WR Featured","WR Slot Limited","WR Wide Limited","WR Non Focal"))
  ) %>%
  # Kicking (safe)
  mutate(
    FGA = rowsum_available(cur_data_all(), c("attempt19","attempt_19","att19","FGA19","fga19","attempt29","attempt_29","att29","FGA29","fga29","attempt39","attempt_39","att39","FGA39","fga39","attempt49","attempt_49","att49","FGA49","fga49","attempt50","attempt_50","att50","FGA50","fga50")),
    FGM = rowsum_available(cur_data_all(), c("complete19","complete_19","made19","FGM19","fgm19","complete29","complete_29","made29","FGM29","fgm29","complete39","complete_39","made39","FGM39","fgm39","complete49","complete_49","made49","FGM49","fgm49","complete50","complete_50","made50","FGM50","fgm50")),
    HC_FGA_Role = mk_role_3(FGA)
  ) %>%
  # OL pressure grade (0–100, higher = better)
  mutate(
    QBP       = suppressWarnings(as.numeric(QBP)),
    PRESS_PCT = pct_num(PRESS_PCT),
    PrROE     = pct_num(PrROE),
    pr_QBP   = safe_percent_rank(QBP),
    pr_PRESS = safe_percent_rank(PRESS_PCT),
    pr_PrROE = safe_percent_rank(PrROE),
    inv_QBP   = 1 - pr_QBP,
    inv_PRESS = 1 - pr_PRESS,
    inv_PrROE = 1 - pr_PrROE,
    Oline_Press_Grade_0to100 = round((0.40*inv_QBP + 0.35*inv_PRESS + 0.25*inv_PrROE) * 100, 1),
    Team_Oline_Press_Role = dplyr::case_when(
      Oline_Press_Grade_0to100 >= 80 ~ "Clean Pocket",
      Oline_Press_Grade_0to100 >= 60 ~ "Protected",
      Oline_Press_Grade_0to100 >= 40 ~ "Balanced Pressure",
      Oline_Press_Grade_0to100 >= 20 ~ "On the Run",
      !is.na(Oline_Press_Grade_0to100) ~ "Under Duress",
      TRUE ~ NA_character_
    ) %>% factor(levels = c("Clean Pocket","Protected","Balanced Pressure","On the Run","Under Duress"))
  ) %>%
  # OL run grade (0–100, higher = better)
  mutate(
    YBCO_CAR = suppressWarnings(as.numeric(YBCO_CAR)),
    pr_YBCO  = safe_percent_rank(YBCO_CAR),
    Oline_Run_Grade_0to100 = round(pr_YBCO * 100, 1),
    Team_Oline_Run_Role = mk_role(YBCO_CAR, c("Road Graders","Physical Frontline","Average Run Block","Run Blocking Liabilities","Struggles to Open Lanes"))
  ) %>%
  # Red zone & scoring roles
  mutate(
    i5_CAR = suppressWarnings(as.numeric(i5_CAR)),
    EZTGT  = suppressWarnings(as.numeric(EZTGT)),
    RZ_opp = coalesce(i5_CAR, 0) + coalesce(EZTGT, 0),
    RZ_Pass_Run = round((coalesce(EZTGT, 0) / pmax(RZ_opp, 1)) * 100, 1),
    Team_RZ_Role = mk_role(RZ_opp, c("High Red Zone Volume","Consistent Red Zone","Average Red Zone","Infrequent Red Zone","Scarce Red Zone")),
    Team_RZ_Pass_Run_Role = mk_role_skew(RZ_Pass_Run, c("Red Zone Air Attack","Pass Centric Red Zone","Balance Red Zone","Red Zone Rushing Attack","Run First Red Zone")),
    Team_Pts_scr_Role = mk_role_skew(Pts_scr, c("Explosive","High Powered","Balance","Ineffective","Stagnant"))
  ) %>%
  # Final cleanup & ordering (your exact two-select finish)
  dplyr::select(-head_coach_pass,-TM_DEF_pass,-head_coach_rush,-TM_DEF_rush,-head_coach,-Location_pass,-Team.Name_pass) %>%
  dplyr::select(Name:BACK_TGT_RATE, pass_yds_pp_rec:xyac_epa_rec, complete19:Team_Pts_scr_Role, Head_Coach, TM_DEF)
