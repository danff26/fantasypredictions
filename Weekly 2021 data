#functions

reorder_like <- function(df, example_cols) {
  keep <- intersect(example_cols, names(df))
  rest <- setdiff(names(df), example_cols)
  dplyr::select(df, dplyr::all_of(keep), dplyr::all_of(rest))
}

rng <- function(df, start, end) {
  nms <- names(df)
  if (!all(c(start, end) %in% nms)) return(character())
  i1 <- match(start, nms); i2 <- match(end, nms)
  nms[seq(min(i1, i2), max(i1, i2))]
}

pct_num <- function(x) {
  # Accepts numeric or "%"/"-%" strings; returns 0–100 numeric
  if (is.numeric(x)) return(x)
  as.numeric(str_replace_all(x, "[-%]", ""))
}

safe_percent_rank <- function(x) {
  if (all(is.na(x))) return(rep(NA_real_, length(x)))
  pr <- dplyr::percent_rank(x)
  if (all(is.na(pr))) rep(0.5, length(x)) else pr
}

pct_num <- function(x) {
  if (is.numeric(x)) return(x)
  as.numeric(gsub("[-%]", "", x))
}

# Percent rank that won't crash on all-NA or zero-variance data
safe_percent_rank_def <- function(x) {
  if (all(is.na(x))) return(rep(NA_real_, length(x)))
  pr <- dplyr::percent_rank(x)
  ifelse(is.na(pr), mean(pr, na.rm = TRUE), pr)
}

# Sum available columns only; returns NA if none found (so you can detect)
rowsum_available <- function(.df, cols) {
  have <- intersect(cols, names(.df))
  if (length(have) == 0) return(rep(NA_real_, nrow(.df)))
  # coerce each to numeric first
  m <- as.data.frame(lapply(.df[have], function(v) suppressWarnings(as.numeric(v))))
  rowSums(m, na.rm = TRUE)
}

mk_role <- function(x, labels, use_median_mean_diff = TRUE) {
  m  <- mean(x, na.rm = TRUE)
  md <- median(x, na.rm = TRUE)
  q1 <- quantile(x, 0.25, na.rm = TRUE, type = 7)
  q3 <- quantile(x, 0.75, na.rm = TRUE, type = 7)
  mmd <- if (use_median_mean_diff) (m - md) else (md - m)
  
  cut_top <- q3
  cut_hiL <- m + mmd
  cut_hiR <- q3
  cut_midL <- (m - mmd)
  cut_midR <- (m + mmd)
  cut_loL  <- q1
  cut_loR  <- (m - mmd)
  
  out <- case_when(
    x >= cut_top ~ labels[1],
    x >= cut_hiL & x < cut_hiR ~ labels[2],
    x >= cut_midL & x < cut_midR ~ labels[3],
    x >= cut_loL & x < cut_loR ~ labels[4],
    x <  q1 ~ labels[5],
    TRUE ~ NA_character_
  )
  factor(out, levels = labels)
}

mk_role_skew <- function(x, labels) {
  m  <- mean(x, na.rm = TRUE)
  md <- median(x, na.rm = TRUE)
  q1 <- quantile(x, 0.25, na.rm = TRUE)
  q3 <- quantile(x, 0.75, na.rm = TRUE)
  mmd <- md - m
  
  cut_top <- q3
  cut_hiL <- m + mmd
  cut_hiR <- q3
  cut_midL <- (m - mmd)
  cut_midR <- (m + mmd)
  cut_loL  <- q1
  cut_loR  <- (m - mmd)
  
  out <- case_when(
    x >= cut_top ~ labels[1],
    x >= cut_hiL & x < cut_hiR ~ labels[2],
    x >= cut_midL & x < cut_midR ~ labels[3],
    x >= cut_loL & x < cut_loR ~ labels[4],
    x <  q1 ~ labels[5],
    TRUE ~ NA_character_
  )
  factor(out, levels = labels)
}

mk_role_3 <- function(x, labels3 = c("Field Goal Heavy","Kicker Average","No Kicker Required")) {
  m  <- mean(x, na.rm = TRUE)
  md <- median(x, na.rm = TRUE)
  q1 <- quantile(x, 0.25, na.rm = TRUE, type = 7)
  q3 <- quantile(x, 0.75, na.rm = TRUE, type = 7)
  mmd <- m - md
  out <- dplyr::case_when(
    x >= q3 ~ labels3[1],
    x >= (m - mmd) & x < q3 ~ labels3[2],
    x <  (m - mmd) ~ labels3[3],
    TRUE ~ NA_character_
  )
  factor(out, levels = labels3)
}

grade_from_role <- function(role_vec, mapping_named) {
  out <- unname(mapping_named[as.character(role_vec)])
  out[is.na(out) & !is.na(role_vec)] <- "C"  # unseen role -> neutral
  out <- ifelse(is.na(role_vec), NA, out)
  factor(out, levels = c("A","B","C","D","F"), ordered = TRUE)
}

# Numeric 0–100 -> letter grade (>=80 A, >=60 B, >=40 C, >=20 D, else F)
grade_from_score <- function(score_0to100) {
  cut(
    score_0to100,
    breaks = c(-Inf,20,40,60,80,Inf),
    labels = c("F","D","C","B","A"),
    right = FALSE,
    ordered_result = TRUE
  )
}

