  mutate(
    WIDE_TGT_RATE   = pct_num(WIDE_TGT_RATE),
    SLOT_TGT_RATE   = pct_num(SLOT_TGT_RATE),
    INLINE_TGT_RATE = coalesce(pct_num(INLINE_TGT_RATE), 0),
    BACK_TGT_RATE   = pct_num(BACK_TGT_RATE),
    
    HC_WIDE_TGT_Role = mk_role_skew(
      WIDE_TGT_RATE,
      labels = c("Perimeter Featured","Perimeter Focus","Perimeter Balance","Perimeter Unemphasized","Perimeter Non Focal")
    ),
    HC_SLOT_TGT_Role = mk_role(
      SLOT_TGT_RATE,
      labels = c("Slot Featured","Slot Focus","Slot Balance","Slot Unemphasized","Slot Non Focal")
    ),
    HC_INLINE_TGT_Role = mk_role(
      INLINE_TGT_RATE,
      labels = c("TE Featured","TE Focus","TE Balance","TE Unemphasized","TE Non Focal")
    ),
    HC_BACK_TGT_Role = mk_role_skew(
      BACK_TGT_RATE,
      labels = c("Checkdown Featured","Checkdown Focus","Checkdown Balance","Checkdown Unemphasized","Checkdown Non Focal")
    ),
    
