grade_from_score <- function(score_0to100) {
  cut(
    score_0to100,
    breaks = c(-Inf, 20, 40, 60, 80, Inf),
    labels = c("F", "D", "C", "B", "A"),
    right = FALSE,
    ordered_result = TRUE
  )
}

safe_cor <- function(x, y) {
  x <- suppressWarnings(as.numeric(x))
  y <- suppressWarnings(as.numeric(y))
  
  if (all(is.na(x)) || all(is.na(y))) return(NA_real_)
  if (sd(x, na.rm = TRUE) == 0 || sd(y, na.rm = TRUE) == 0) return(NA_real_)
  
  cor(x, y, use = "pairwise.complete.obs")
}

rescale_0_100 <- function(x) {
  rng <- range(x, na.rm = TRUE)
  if (!all(is.finite(rng)) || diff(rng) == 0) return(rep(50, length(x)))
  (x - rng[1]) / diff(rng) * 100
}

pct_score <- function(x, inverse = FALSE) {
  x_num <- suppressWarnings(as.numeric(x))
  out <- dplyr::percent_rank(x_num) * 100
  
  default_val <- median(out, na.rm = TRUE)
  if (!is.finite(default_val)) default_val <- 50
  
  out[is.na(out)] <- default_val
  if (inverse) out <- 100 - out
  
  as.numeric(out)
}

role_score_from_target <- function(role_vec, target_vec) {
  d <- tibble::tibble(
    role = as.character(role_vec),
    target = suppressWarnings(as.numeric(target_vec))
  ) %>%
    dplyr::filter(!is.na(role), !is.na(target))
  
  if (nrow(d) == 0) return(rep(50, length(role_vec)))
  
  level_means <- d %>%
    dplyr::group_by(role) %>%
    dplyr::summarise(mean_target = mean(target, na.rm = TRUE), .groups = "drop")
  
  level_means$score_0to100 <- rescale_0_100(level_means$mean_target)
  
  score_map <- setNames(level_means$score_0to100, level_means$role)
  out <- unname(score_map[as.character(role_vec)])
  
  default_val <- mean(level_means$score_0to100, na.rm = TRUE)
  if (!is.finite(default_val)) default_val <- 50
  
  out[is.na(out)] <- default_val
  as.numeric(out)
}

row_weighted_mean <- function(df, weights) {
  mat <- as.matrix(df)
  weights <- as.numeric(weights)
  
  num <- rowSums(sweep(mat, 2, weights, `*`), na.rm = TRUE)
  den <- rowSums((!is.na(mat)) * matrix(weights, nrow = nrow(mat), ncol = ncol(mat), byrow = TRUE))
  
  ifelse(den == 0, NA_real_, num / den)
}

build_group_score <- function(data, score_cols, target_col = "FP") {
  score_cols <- intersect(score_cols, names(data))
  
  if (length(score_cols) == 0) {
    return(rep(NA_real_, nrow(data)))
  }
  
  w <- sapply(score_cols, function(col) abs(safe_cor(data[[col]], data[[target_col]])))
  w[is.na(w)] <- 0
  
  if (sum(w) == 0) w[] <- 1
  w <- w / sum(w)
  
  row_weighted_mean(data[, score_cols, drop = FALSE], w)
}

build_weighted_metric <- function(data, weight_map) {
  keep_cols <- names(weight_map)[names(weight_map) %in% names(data)]
  
  if (length(keep_cols) == 0) {
    return(rep(NA_real_, nrow(data)))
  }
  
  w <- weight_map[keep_cols]
  w <- w / sum(w)
  
  row_weighted_mean(data[, keep_cols, drop = FALSE], w)
}

