      (w_qbp_def * pr_qbp_def + w_press_def * pr_press_def + w_prroe_def * pr_prroe_def) * 100,
      1
    ),
    
    Team_QBP_DEF_Role_avg = mk_role(
      avg_total_QBP,
      labels = c("Dominant Pass Rush","Effective Pass Rush","Average Rush","Ineffective Pass Rush","No QB Pressure")
    ),
    Team_QBP_DEF_Role_avg = factor(
      Team_QBP_DEF_Role_avg,
      levels = c("No QB Pressure","Ineffective Pass Rush","Average Rush","Effective Pass Rush","Dominant Pass Rush")
    ),
    
    Team_PRESS_PCT_DEF_Role_avg = mk_role(
      avg_total_PRESS_PCT,
      labels = c("QB Hounding","Relentless Pass Rush","Pressure Balance","Passive Pass Rush","Weak Pass Rush")
    ),
    Team_PRESS_PCT_DEF_Role_avg = factor(
      Team_PRESS_PCT_DEF_Role_avg,
      levels = c("Weak Pass Rush","Passive Pass Rush","Pressure Balance","Relentless Pass Rush","QB Hounding")
    ),
    
    Team_PrROE_DEF_Role_avg = mk_role(
      avg_total_PrROE,
      labels = c("Heavy Pressure","Aggressive Pass Rush","PrROE Balance","Slow to Collapse","Allowing Clean Pocket")
    ),
    Team_PrROE_DEF_Role_avg = factor(
      Team_PrROE_DEF_Role_avg,
      levels = c("Allowing Clean Pocket","Slow to Collapse","PrROE Balance","Aggressive Pass Rush","Heavy Pressure")
    ),
    
    Team_Dline_Press_Role_avg = case_when(
      Dline_Press_Grade_0to100_avg >= 80 ~ "Dominant Pass Rush",
      Dline_Press_Grade_0to100_avg >= 60 ~ "Relentless Pass Rush",
      Dline_Press_Grade_0to100_avg >= 40 ~ "Balanced Pressure",
      Dline_Press_Grade_0to100_avg >= 20 ~ "Passive Pass Rush",
      !is.na(Dline_Press_Grade_0to100_avg) ~ "No QB Pressure",
      TRUE ~ NA_character_
    ),
    Team_Dline_Press_Role_avg = factor(
      Team_Dline_Press_Role_avg,
      levels = c("Dominant Pass Rush","Relentless Pass Rush","Balanced Pressure","Passive Pass Rush","No QB Pressure")
    )
  ) |>
  mutate(
    # -------------------- Red zone / points allowed --------------------
    Team_RZ_DEF_Role_avg = mk_role(
      avg_total_RZ_opp_Allw,
