# -------------------------------------------------------------------
# 1) Helper functions
# -------------------------------------------------------------------

if (!exists("rmse")) {
  rmse <- function(actual, predicted) {
    sqrt(mean((actual - predicted)^2, na.rm = TRUE))
  }
}

if (!exists("mae")) {
  mae <- function(actual, predicted) {
    mean(abs(actual - predicted), na.rm = TRUE)
  }
}

if (!exists("rsq")) {
  rsq <- function(actual, predicted) {
    1 - sum((actual - predicted)^2, na.rm = TRUE) /
      sum((actual - mean(actual, na.rm = TRUE))^2, na.rm = TRUE)
  }
}

if (!exists("safe_cor")) {
  safe_cor <- function(x, y) {
    x <- suppressWarnings(as.numeric(x))
    y <- suppressWarnings(as.numeric(y))
    
    if (all(is.na(x)) || all(is.na(y))) return(NA_real_)
    if (sd(x, na.rm = TRUE) == 0 || sd(y, na.rm = TRUE) == 0) return(NA_real_)
    
    cor(x, y, use = "pairwise.complete.obs")
  }
}

if (!exists("calc_vif_table")) {
  calc_vif_table <- function(df, features) {
    features <- features[features %in% names(df)]
    
    if (length(features) <= 1) {
      return(tibble::tibble(feature = features, vif = 1))
    }
    
    d <- df[, features, drop = FALSE]
    d <- d[stats::complete.cases(d), , drop = FALSE]
    
    if (nrow(d) < 10) {
      return(tibble::tibble(feature = features, vif = NA_real_))
    }
    
    vif_vals <- sapply(features, function(f) {
      others <- setdiff(features, f)
      
      if (length(others) == 0) return(1)
      
      fit <- stats::lm(
        stats::as.formula(paste(f, "~", paste(others, collapse = " + "))),
        data = d
      )
      
      r2 <- summary(fit)$r.squared
      if (is.na(r2) || r2 >= 0.9999) return(Inf)
      
      1 / (1 - r2)
    })
    
    tibble::tibble(
      feature = names(vif_vals),
      vif = as.numeric(vif_vals)
    )
  }
}

if (!exists("fit_target_model")) {
  fit_target_model <- function(train_df, test_df, full_df, target, features, clip_zero = TRUE) {
    features <- features[features %in% names(train_df)]
    
    if (!(target %in% names(train_df)) || length(features) == 0) {
      return(NULL)
    }
    
    train_use <- train_df %>%
      dplyr::select(dplyr::all_of(c(target, features))) %>%
      dplyr::filter(stats::complete.cases(.))
    
    test_use <- test_df %>%
      dplyr::select(dplyr::all_of(c(target, features))) %>%
      dplyr::filter(stats::complete.cases(.))
    
    if (nrow(train_use) < 20 || nrow(test_use) < 5) {
      return(NULL)
    }
    
    model_formula <- stats::as.formula(
      paste(target, "~", paste(features, collapse = " + "))
    )
    
    fit <- stats::lm(model_formula, data = train_use)
    
    pred_test <- stats::predict(fit, newdata = test_use)
    pred_full <- stats::predict(fit, newdata = full_df)
    
    if (clip_zero) {
      pred_test <- ifelse(is.na(pred_test), NA_real_, pmax(0, pred_test))
      pred_full <- ifelse(is.na(pred_full), NA_real_, pmax(0, pred_full))
    }
    
    metrics <- tibble::tibble(
      target = target,
      features = paste(features, collapse = " + "),
      n_train = nrow(train_use),
      n_test = nrow(test_use),
      rmse = rmse(test_use[[target]], pred_test),
      mae = mae(test_use[[target]], pred_test),
      r2 = rsq(test_use[[target]], pred_test),
      correlation = safe_cor(test_use[[target]], pred_test)
    )
    
    vif_tbl <- calc_vif_table(train_use, features) %>%
      dplyr::mutate(target = target)
    
    list(
      fit = fit,
      pred_full = pred_full,
      metrics = metrics,
      vif = vif_tbl
    )
  }
}

