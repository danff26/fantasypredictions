    )
  ) |>
  mutate(
    # -------------------- Run defense --------------------
    HC_DEF_Rush_Eff_Role_avg = mk_role(
      avg_total_YPC,
      labels = c("Easily Gashed","Run Allowing","Average Rush DEF","Imposing Run DEF","Stout Run DEF")
    ),
    HC_DEF_Rush_Eff_Role_avg = factor(
      HC_DEF_Rush_Eff_Role_avg,
      levels = c("Stout Run DEF","Imposing Run DEF","Average Rush DEF","Run Allowing","Easily Gashed")
    ),
    
    HC_Dline_YBC_Run_Role_avg = mk_role(
      avg_total_YBCO_CAR,
      labels = c("Blown Off the Ball","Pushed Off the Ball","Stalemate","Win at the Line","Penetrating")
    ),
    HC_Dline_YBC_Run_Role_avg = factor(
      HC_Dline_YBC_Run_Role_avg,
      levels = c("Penetrating","Win at the Line","Stalemate","Pushed Off the Ball","Blown Off the Ball")
    ),
    
    HC_Dline_YACO_Run_Role_avg = mk_role(
      avg_total_YACO_CAR,
      labels = c("Poor Tackling","Weak Tackling","Tackle Average","Fundamental Tackling","No Extra Yards")
    ),
    HC_Dline_YACO_Run_Role_avg = factor(
      HC_Dline_YACO_Run_Role_avg,
      levels = c("No Extra Yards","Fundamental Tackling","Tackle Average","Weak Tackling","Poor Tackling")
    ),
    
    pr_ybc_def  = safe_percent_rank(avg_total_YBCO_CAR),
    pr_yaco_def = safe_percent_rank(avg_total_YACO_CAR),
    
    inv_ybc_def  = 1 - pr_ybc_def,
    inv_yaco_def = 1 - pr_yaco_def,
    
    Dline_Run_Grade_0to100_avg = round(
      (w_ybc_def * inv_ybc_def + w_yaco_def * inv_yaco_def) * 100,
      1
    ),
    
    Team_Dline_Run_Role_avg = case_when(
      Dline_Run_Grade_0to100_avg >= 80 ~ "Stout Run DEF",
      Dline_Run_Grade_0to100_avg >= 60 ~ "Win at the Line",
      Dline_Run_Grade_0to100_avg >= 40 ~ "Average Rush DEF",
      Dline_Run_Grade_0to100_avg >= 20 ~ "Pushed Off the Ball",
      !is.na(Dline_Run_Grade_0to100_avg) ~ "Easily Gashed",
      TRUE ~ NA_character_
    ),
    Team_Dline_Run_Role_avg = factor(
      Team_Dline_Run_Role_avg,
      levels = c("Stout Run DEF","Win at the Line","Average Rush DEF","Pushed Off the Ball","Easily Gashed")
    )
  ) |>
  mutate(
    # -------------------- Target funnel / target tightness --------------------
    HC_WIDE_TGT_DEF_Role_avg = mk_role_skew(
      avg_total_WIDE_TGT_RATE,
      labels = c("Perimeter Funnel","Perimeter Allw","Perimeter Balance","Perimeter Tight","Perimeter Unbending")
    ),
    
    HC_SLOT_TGT_DEF_Role_avg = mk_role(
      avg_total_SLOT_TGT_RATE,
      labels = c("Slot Funnel","Slot Allw","Slot Balance","Slot Tight","Slot Unbending")
    ),
    
    HC_INLINE_TGT_DEF_Role_avg = mk_role(
      avg_total_INLINE_TGT_RATE,
      labels = c("TE Funnel","TE Allw","TE Balance","TE Tight","TE Unbending")
    ),
    HC_INLINE_TGT_DEF_Role_avg = factor(
      HC_INLINE_TGT_DEF_Role_avg,
      levels = c("TE Unbending","TE Tight","TE Balance","TE Allw","TE Funnel")
    ),
    
    HC_BACK_TGT_DEF_Role_avg = mk_role_skew(
      avg_total_BACK_TGT_RATE,
      labels = c("Checkdown Funnel","Checkdown Allw","Checkdown Balance","Checkdown Tight","Checkdown Unbending")
    ),
    HC_BACK_TGT_DEF_Role_avg = factor(
      HC_BACK_TGT_DEF_Role_avg,
      levels = c("Checkdown Unbending","Checkdown Tight","Checkdown Balance","Checkdown Allw","Checkdown Funnel")
    ),
    
    HC_WR_TGT_DEF_Role_avg = case_when(
      (HC_WIDE_TGT_DEF_Role_avg %in% c("Perimeter Funnel","Perimeter Allw")) &
        (HC_SLOT_TGT_DEF_Role_avg %in% c("Slot Tight","Slot Unbending")) ~ "Perimeter Funnel",
      
      (HC_WIDE_TGT_DEF_Role_avg %in% c("Perimeter Tight","Perimeter Unbending")) &
        (HC_SLOT_TGT_DEF_Role_avg %in% c("Slot Funnel","Slot Allw")) ~ "Slot Funnel",
      
      (HC_WIDE_TGT_DEF_Role_avg == "Perimeter Balance") &
        (HC_SLOT_TGT_DEF_Role_avg == "Slot Balance") ~ "Balance",
      
      (HC_WIDE_TGT_DEF_Role_avg %in% c("Perimeter Funnel","Perimeter Allw")) &
        (HC_SLOT_TGT_DEF_Role_avg == "Slot Balance") ~ "Perimeter Lean",
      
      (HC_WIDE_TGT_DEF_Role_avg == "Perimeter Balance") &
        (HC_SLOT_TGT_DEF_Role_avg %in% c("Slot Funnel","Slot Allw")) ~ "Slot Lean",
      
      (HC_WIDE_TGT_DEF_Role_avg %in% c("Perimeter Funnel","Perimeter Allw")) &
        (HC_SLOT_TGT_DEF_Role_avg %in% c("Slot Funnel","Slot Allw")) ~ "WR Funnel",
      
      (HC_WIDE_TGT_DEF_Role_avg %in% c("Perimeter Tight","Perimeter Unbending")) &
        (HC_SLOT_TGT_DEF_Role_avg == "Slot Balance") ~ "WR Slot Limited",
      
      (HC_WIDE_TGT_DEF_Role_avg == "Perimeter Balance") &
        (HC_SLOT_TGT_DEF_Role_avg %in% c("Slot Tight","Slot Unbending")) ~ "WR Wide Limited",
      
      (HC_WIDE_TGT_DEF_Role_avg %in% c("Perimeter Tight","Perimeter Unbending")) &
        (HC_SLOT_TGT_DEF_Role_avg %in% c("Slot Tight","Slot Unbending")) ~ "WR Unbending",
      
      TRUE ~ NA_character_
    ),
    HC_WR_TGT_DEF_Role_avg = factor(
      HC_WR_TGT_DEF_Role_avg,
      levels = c(
        "Perimeter Funnel","Slot Funnel","Balance","Perimeter Lean",
        "Slot Lean","WR Funnel","WR Slot Limited","WR Wide Limited","WR Unbending"
      )
    ),
    
    HC_FGA_DEF_Role_avg = mk_role_3(
      avg_total_FGA_DEF,
      labels3 = c("Field Goal Heavy Allw","Kicker Average Allw","No Kicker Allw")
    )
  ) |>
  mutate(
    # -------------------- Pass rush / defensive line pressure --------------------
    pr_qbp_def   = safe_percent_rank(avg_total_QBP),
    pr_press_def = safe_percent_rank(avg_total_PRESS_PCT),
    pr_prroe_def = safe_percent_rank(avg_total_PrROE),
    
